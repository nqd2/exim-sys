@startuml usecase-overview
!include ./astah-style.puml
left to right direction

title Use Case Tong Quan - He thong dat hang nhap khau

actor "Sales Department" as Sales
actor "International Ordering Department" as IOD
actor "Overseas Import Site" as Site
actor "Warehouse Management Department" as WH
actor "System Administrator" as Admin

rectangle "Import Assignment System" {
  usecase "Manage Import Requests" as UC1
  usecase "Manage Site Information" as UC2
  usecase "Collect Inventory Data" as UC3
  usecase "Plan Import Allocation" as UC4
  usecase "Place Overseas Orders" as UC5
  usecase "Receive and Reconcile Goods" as UC6
  usecase "Administer System" as UC7
}

Sales --> UC1
IOD --> UC1
IOD --> UC2
IOD --> UC3
IOD --> UC4
IOD --> UC5
Site --> UC2
Site --> UC3
Site --> UC5
WH --> UC6
Admin --> UC7

UC4 ..> UC3 : <<include>>
UC5 ..> UC4 : <<include>>
UC6 ..> UC5 : <<include>>

@enduml
